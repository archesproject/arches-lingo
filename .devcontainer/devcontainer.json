{
    "name": "Arches Lingo",
    "dockerComposeFile": "docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/workspaces/arches-lingo",
    "features": {},
    "forwardPorts": [8000, 8022],
    "portsAttributes": {
        "8000": {
            "label": "Django",
            "onAutoForward": "openBrowser"
        },
        "8022": {
            "label": "Webpack Dev Server",
            "onAutoForward": "ignore"
        }
    },
    "containerEnv": {
        "PGHOST": "db",
        "PGPORT": "5432",
        "PGUSER": "postgres",
        "PGPASSWORD": "postgis",
        "PGDATABASE": "arches_lingo",
        "ARCHES_ESHOST": "elasticsearch",
        "ARCHES_ESPORT": "9200",
        "ARCHES_ESPROTOCOL": "http",
        "ARCHES_ESUSER": "elastic",
        "ARCHES_ESPASSWORD": "E1asticSearchforArche5",
        "ARCHES_ESVALIDATE": "False",
        "ARCHES_DJANGO_DEBUG": "True"
    },
    "onCreateCommand": "bash .devcontainer/on-create.sh",
    "postStartCommand": "bash .devcontainer/post-start.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.debugpy",
                "dbaeumer.vscode-eslint",
                "Vue.volar",
                "ms-python.black-formatter"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/workspaces/arches-lingo/.venv/bin/python",
                "python.terminal.activateEnvironment": true
            }
        }
    }
}
